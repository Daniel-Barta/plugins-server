NODE_ENV="development" # Options: 'development', 'production'
PORT="8080"
HOST="localhost"

# CORS Settings
CORS_ORIGIN="http://localhost:*" # Allowed CORS origin, adjust as necessary

# Rate Limiting
COMMON_RATE_LIMIT_WINDOW_MS="1000" # Window size for rate limiting (ms)
COMMON_RATE_LIMIT_MAX_REQUESTS="100" # Max number of requests per window per IP

# API Key
API_KEY="supersecretapikey"

# Headless Browser Settings
REUSE_BROWSER_INSTANCE="false" # Set to "true" to reuse browser instances for better performance (default: false)
